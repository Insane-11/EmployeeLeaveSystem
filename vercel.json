{
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/employee-leave-ui/browser",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://employeeleavesystem-w4mo.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
